{
    "name": "@solana/connector",
    "version": "0.2.6",
    "description": "Headless wallet connector client and React provider built on Wallet Standard",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./headless": {
            "types": "./dist/headless.d.ts",
            "import": "./dist/headless.mjs",
            "require": "./dist/headless.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.mjs",
            "require": "./dist/react.js"
        },
        "./compat": {
            "types": "./dist/compat.d.ts",
            "import": "./dist/compat.mjs",
            "require": "./dist/compat.js"
        },
        "./remote": {
            "types": "./dist/remote.d.ts",
            "import": "./dist/remote.mjs",
            "require": "./dist/remote.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.mjs",
            "require": "./dist/server.js"
        }
    },
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "tsup",
        "build:analyze": "npm run build && node scripts/analyze-bundle.js",
        "dev": "tsup --watch",
        "type-check": "tsc --noEmit",
        "lint": "prettier --check src/",
        "clean": "rm -rf dist",
        "size": "size-limit",
        "size:why": "size-limit --why",
        "perf": "npm run build:analyze && npm run size",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "peerDependencies": {
        "@solana/keychain": "^1.2.0",
        "@solana/keychain-aws-kms": "^1.2.0",
        "@solana/keychain-fireblocks": "^1.2.0",
        "@solana/keychain-privy": "^1.2.0",
        "@solana/keychain-turnkey": "^1.2.0",
        "@solana/keychain-vault": "^1.2.0",
        "@solana/web3.js": "^1.0.0",
        "@walletconnect/universal-provider": "^2.23.9",
        "react": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "@walletconnect/universal-provider": {
            "optional": true
        },
        "@solana/connector-debugger": {
            "optional": true
        },
        "@solana/web3.js": {
            "optional": true
        },
        "@solana/keychain": {
            "optional": true
        },
        "@solana/keychain-fireblocks": {
            "optional": true
        },
        "@solana/keychain-privy": {
            "optional": true
        },
        "@solana/keychain-turnkey": {
            "optional": true
        },
        "@solana/keychain-vault": {
            "optional": true
        },
        "@solana/keychain-aws-kms": {
            "optional": true
        }
    },
    "dependencies": {
        "@noble/ciphers": "1.3.0",
        "@noble/curves": "1.9.7",
        "@noble/hashes": "1.8.0",
        "@solana-mobile/wallet-standard-mobile": "^0.5.2",
        "@solana/addresses": "^6.9.0",
        "@solana/codecs": "^6.9.0",
        "@solana/keys": "^6.9.0",
        "@solana/kit": "^6.9.0",
        "@solana/signers": "^6.9.0",
        "@solana/transaction-messages": "^6.9.0",
        "@solana/transactions": "^6.9.0",
        "@solana/webcrypto-ed25519-polyfill": "^6.9.0",
        "@wallet-standard/app": "^1.1.0",
        "@wallet-standard/base": "^1.1.0",
        "@wallet-standard/features": "^1.1.0",
        "@wallet-ui/core": "^4.1.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.15",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "happy-dom": "^20.9.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tsup": "^8.5.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/solana-foundation/connectorkit"
    }
}
