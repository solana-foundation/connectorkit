{
    "name": "@solana/connector-debugger",
    "version": "0.2.1",
    "description": "Framework-agnostic devtools for @solana/connector",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "type-check": "tsc --noEmit",
        "lint": "prettier --check src/",
        "clean": "rm -rf dist"
    },
    "peerDependencies": {
        "@solana/connector": ">=0.1.0"
    },
    "peerDependenciesMeta": {
        "@solana/connector": {
            "optional": true
        }
    },
    "devDependencies": {
        "@solana/connector": "workspace:*",
        "tsup": "^8.5.0",
        "typescript": "^6.0.3"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/solana-foundation/connectorkit",
        "directory": "packages/devtools"
    },
    "keywords": [
        "solana",
        "wallet",
        "devtools",
        "debugging",
        "connector"
    ],
    "dependencies": {
        "@coral-xyz/anchor": "^0.32.1",
        "@solana-program/compute-budget": "^0.16.0",
        "@solana-program/program-metadata": "^0.7.0",
        "@solana-program/system": "^0.12.2",
        "@solana-program/token": "^0.14.0",
        "@solana-program/token-2022": "^0.12.0",
        "@solana/codecs": "^6.9.0",
        "@solana/kit": "^6.9.0",
        "@solana/transaction-messages": "^6.9.0",
        "@solana/transactions": "^6.9.0",
        "@solana/web3.js": "^1.98.4",
        "bn.js": "^5.2.4"
    }
}
